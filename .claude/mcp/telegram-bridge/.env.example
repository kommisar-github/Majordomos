# Telegram Bot Configuration
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram user ID (send /start to @userinfobot to get it)
TELEGRAM_ALLOWED_USER=123456789

# Task-router server URL (default: localhost)
TASK_ROUTER_URL=http://127.0.0.1:3100

# Optional: shared secret for /api/* (match the value set when starting the
# task-router server). Leave blank if the server does not set TASK_ROUTER_API_KEY.
# TASK_ROUTER_API_KEY=

# Project name (must match TASK_ROUTER_PROJECT used by agent terminals —
# typically your workspace folder name)
TASK_ROUTER_PROJECT=my-app

# How often to poll task-router for PM responses (ms)
POLL_INTERVAL_MS=5000

# How often to re-register with task-router to prevent TTL expiry (ms)
KEEPALIVE_INTERVAL_MS=60000
