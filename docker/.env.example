# Copy to `.env` (same dir) and fill in. NEVER commit a real .env — it holds your token.
# The .env is git/docker-ignored; see .gitignore / .dockerignore.

# The LOCAL image tag to run. There is NO registry: download the release tarball and
#   docker load < task-router-<ver>.tar.gz
# which loads this tag. (Or build it yourself: tools/build-image.sh --save <file>.)
TR_IMAGE=task-router:2.1.10

# Absolute host path to bind-mount into the container at the SAME path (host path == container path).
# This is the PARENT dir that holds your project at  $TR_WORKSPACE/$TR_PROJECT. Point it at a parent
# (not the project itself) so any symlinks your project makes to things OUTSIDE it — e.g. a sibling
# folder one level up — still resolve inside the container. `server` and `app` mount this identically.
# The project must already be seeded (.claude/mcp/task-router/agents.json + .mcp.json present).
TR_WORKSPACE=/absolute/path/to/parent

# Project/tenant name — must match the repo's .mcp.json ?project=<name>, AND be the project's
# subfolder name under TR_WORKSPACE (the project root is  $TR_WORKSPACE/$TR_PROJECT).
TR_PROJECT=myapp

# Claude Code OAuth token. Mint one with:  claude setup-token
CLAUDE_TOKEN=

# Host user ids so agent writes to the mounted repo land as you (Linux/macOS: `id -u` / `id -g`).
UID=1000
GID=1000

# --- Optional: server + App settings (same TASK_ROUTER_* names the IDE start scripts bake in) ---
# All have sensible container defaults if left unset.
# Server-side (drive the server service):
TASK_ROUTER_HOST=127.0.0.1            # keep loopback unless you publish :3100 for federation
TASK_ROUTER_ERRATA_CHANNEL=disabled  # e.g. github:owner/repo or folder:/path (mount the folder too)
TASK_ROUTER_IDLE_SHUTDOWN=0          # 0 = always-on (headless contract)
#TASK_ROUTER_API_KEY=                # optional REST/MCP key; loopback is trusted without one
# App-side (drive the app service):
TASK_ROUTER_UI_HOST=0.0.0.0          # keep 0.0.0.0 (the dashboard must bind all netns interfaces to be published)
#TASK_ROUTER_CLAUDE_FLAGS=--dangerously-skip-permissions
#TASK_ROUTER_MODEL_BY_ROLE={"pm":"opus","review":"opus"}

# --- Remote access (default: BOTH surfaces loopback-only / unreachable from other machines) ---
# Publish binds live on the server service. Set to 0.0.0.0 (all interfaces) or a specific LAN IP to expose.
# READ "Trust boundary" in README.md FIRST: the dashboard is UNAUTHENTICATED + RCE-grade, the IP allow-list
# needs the REAL client IP (works on native Linux Docker; Docker Desktop's NAT hides it), and there is no
# TLS (cleartext on the LAN). Gate every exposed surface with its allow-list.
#TR_UI_PUBLISH_HOST=0.0.0.0                       # expose the DASHBOARD (:3200) — REQUIRES the two UI vars below
#TR_FED_PUBLISH_HOST=0.0.0.0                      # expose FEDERATION (:3100) — also set TASK_ROUTER_HOST=0.0.0.0
#TASK_ROUTER_UI_IP_ALLOWLIST=10.0.0.5,10.0.0.6   # exact client IPs allowed to the dashboard (loopback always ok)
#TASK_ROUTER_UI_ALLOWED_HOSTS=tr.corp.local      # extra Host: names accepted (anti-DNS-rebinding)
#TASK_ROUTER_SERVER_IP_ALLOWLIST=10.0.0.5        # exact IPs allowed to federation (defense-in-depth over trtok_)

# --- Optional pass-through to `claude` (verified names; code.claude.com/docs/en/env-vars) ---
# Uncomment ONLY the ones you need. The compose forwards these to the agents' claude process, and
# each is passed through ONLY when set here — an unset one is not defined in the container at all.
#ANTHROPIC_AUTH_TOKEN=                       # custom Authorization: Bearer token (gateway/proxy auth)
#ANTHROPIC_BASE_URL=https://gateway.internal # route claude to a proxy/gateway endpoint
#ANTHROPIC_CUSTOM_HEADERS=X-Org-Route: prod  # extra request headers ("Name: Value" per line)
#NODE_EXTRA_CA_CERTS=/absolute/path/to/parent/corp-ca.pem  # CA bundle for corporate TLS inspection (PREFERRED; must live under the mounted TR_WORKSPACE)
#NODE_TLS_REJECT_UNAUTHORIZED=0              # disables ALL TLS verification (blunt/insecure; prefer NODE_EXTRA_CA_CERTS)
#DISABLE_TELEMETRY=1                         # opt out of telemetry
#CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1  # disable autoupdater+telemetry+error-reporting+feedback
